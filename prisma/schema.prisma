

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id Int @id @default(autoincrement())
  name String
  external_id String @unique
  createdAt DateTime @default(now())
  integrations Integration[]

}

model Integration {
  id Int @id @default(autoincrement())
  name String
  events Event[]
  clientId Int
  client Client @relation(fields: [clientId], references: [id])
  companyId String?
}

model Event {
  id Int @id @default(autoincrement())
  type String
  url String
  integrationId Int
  integations Integration @relation(fields: [integrationId], references: [id])

}